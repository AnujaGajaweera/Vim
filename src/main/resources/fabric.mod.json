{
  "schemaVersion": 1,
  "id": "vanadium",
  "version": "${version}",
  "name": "Vanadium",
  "description": "Vulkan-native SPIR-V shader loader and manager for Minecraft via VulkanMod.",
  "authors": [
    "Vanadium Maintainers"
  ],
  "contact": {
    "email": "anujagajaweera@gmail.com",
    "homepage": "https://github.com/AnujaGajaweera/Vanadium",
    "sources": "https://github.com/AnujaGajaweera/Vanadium",
    "issues": "https://github.com/AnujaGajaweera/Vanadium/issues"
  },
  "license": "${license}",
  "icon": "assets/vanadium/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "net.vanadium.mod"
    ],
    "client": [
      "net.vanadium.VanadiumClient"
    ]
  },
  "mixins": [
    "vanadium.mixins.json",
    {
      "config": "vanadium.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "fabric-api": "*",
    "vulkanmod": "*"
  }
}
